{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://gcfqbdpmyrijkhejgmml.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "baby-ai-mcp",
      "version": "0.1.0",
      "title": "Baby AI"
    },
    "tools": [
      {
        "name": "chat_with_baby",
        "title": "Chat with Baby AI",
        "description": "Send a message to Baby AI and get a single reply using the Lovable AI Gateway. Stateless — pass any relevant context in the prompt.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "prompt": {
              "type": "string",
              "minLength": 1,
              "description": "The user prompt for Baby AI."
            },
            "system": {
              "description": "Optional system instructions to steer the reply.",
              "type": "string"
            }
          },
          "required": [
            "prompt"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_memories",
        "title": "List memories",
        "description": "Return the signed-in user's saved long-term memories from Baby AI, newest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Maximum memories to return. Defaults to 50.",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "save_memory",
        "title": "Save memory",
        "description": "Save a durable memory Baby AI should remember about the signed-in user (facts, preferences, context).",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "content": {
              "type": "string",
              "minLength": 1,
              "description": "The memory text to store."
            }
          },
          "required": [
            "content"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "delete_memory",
        "title": "Delete memory",
        "description": "Delete one of the signed-in user's saved memories by ID.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "The memory ID to delete."
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
